# Secrets
.env
Backend/.env

# VS Code – machine-specific settings
.vscode/

# Backend – only track core files
Backend/*.py
!Backend/generate_puzzle.py
!Backend/generate_weekly_puzzle.py
!Backend/generate_wotd.py
!Backend/upgrade_clues.py
!Backend/expand_validated.py
!Backend/generate_backword.py
!Backend/recategorise_backword.py
!Backend/fix_answer_leakage.py
Backend/clean_progress.json
Backend/word_bank_backup.json
Backend/leaky_entries.json
Backend/fix_progress.json
Backend/.venv/
Backend/__pycache__/
Backend/archive/
Backend/puzzles/
Backend/puzzles_new/
Backend/puzzles_weekly/
Backend/supabase/*
!Backend/supabase/schema.sql

# Xcode
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcuserstate
DerivedData/
build/
Config.xcconfig

# Exclude Xcode workspace settings (user and shared)
Backword.xcodeproj/project.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings
Backword.xcodeproj/project.xcworkspace/xcuserdata/*/WorkspaceSettings.xcsettings

# macOS
.DS_Store
